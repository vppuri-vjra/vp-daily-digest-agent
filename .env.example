# ── VP Daily Digest Agent — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# Gmail account used to send the digest emails (App Password required, not your normal password)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Recipient
NOTIFY_EMAIL=vp.puri@gmail.com

# Slack bot token (chat:write scope, bot must be invited to the target channel)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=#engg-2pm-in

# Google OAuth2 (Desktop app client) for the Calendar agent — see README.md for setup.
# GOOGLE_OAUTH_REFRESH_TOKEN comes from running get_refresh_token.py locally once.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token
CALENDAR_ID=primary
EVENT_TIMEZONE=America/Los_Angeles
